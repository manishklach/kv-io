+// SPDX-License-Identifier: GPL-2.0
+/*
+ * blk-cgroup AI I/O controller scaffold — Kairo
+ *
+ * RFC/POC — Not for LKML submission.
+ *
+ * Provides a conceptual blk-cgroup policy that maps Kairo request
+ * classes (decode, prefetch, prefill, eviction) to per-cgroup I/O
+ * budgets, weights, and dispatch policies.
+ *
+ * LINUX-6.8-CHECK: This file uses blkcg_policy, blkg_lookup,
+ * blkcg_policy_register, and cgroup file handling patterns from
+ * Linux 6.8 block/blk-cgroup.c, block/blk-iocost.c, and
+ * block/blk-throttle.c.
+ */
+
+#include <linux/blk-cgroup.h>
+#include <linux/blk-mq.h>
+#include <linux/slab.h>
+#include <linux/atomic.h>
+
+/*
+ * struct kairo_blkg_policy
+ *
+ * Per-cgroup Kairo I/O policy.  Attached to a blkcg_gq via the
+ * blkcg_policy framework.  Controls how Kairo-classified requests
+ * from this cgroup are scheduled relative to other cgroups.
+ *
+ * CONCEPTUAL-HOOK: Allocation and free functions exist but are not
+ * registered with blkcg_policy_register().
+ */
+struct kairo_blkg_policy {
+	/* Policy class for this cgroup */
+	enum kairo_blkg_policy_class policy_class;
+
+	/* Target decode tail latency in microseconds */
+	u64 target_decode_p99_us;
+
+	/* Relative I/O weights across Kairo classes */
+	u32 decode_weight;
+	u32 prefetch_weight;
+	u32 write_weight;
+	u32 eviction_weight;
+
+	/* Policy flags */
+	bool allow_recompute_eviction;
+	bool enable_adaptive_controller;
+	bool enable_model_fairness;
+};
+
+/*
+ * struct kairo_blkg_stats
+ *
+ * Per-cgroup Kairo I/O statistics.  Incremented by the conceptual
+ * hooks in kairo_blkg_* functions.
+ *
+ * CONCEPTUAL-HOOK: These counters are not wired to sysfs or cgroup
+ * filesystem yet.
+ */
+struct kairo_blkg_stats {
+	u64 decode_dispatches;
+	u64 prefetch_dispatches;
+	u64 prefill_writes;
+	u64 evictions;
+	u64 throttled_prefetches;
+	u64 demoted_writes;
+	u64 latency_violations;
+};
+
+/*
+ * kairo_blkg_policy_from_request
+ *
+ * Look up the Kairo blk-cgroup policy for a given request.
+ *
+ * Uses bio_blkcg(bio) to find the cgroup, then blkg_lookup to find
+ * the blkcg_gq, then blkg_to_pd to retrieve the per-policy data.
+ *
+ * CONCEPTUAL-HOOK: This function is defined but not called from any
+ * dispatch path.
+ *
+ * LINUX-6.8-CHECK: blkg_lookup signature and blkg_to_pd macro may
+ * differ across kernel versions.
+ */
+static struct kairo_blkg_policy * __maybe_unused
+kairo_blkg_policy_from_request(struct request *rq)
+{
+	struct blkcg_gq *blkg;
+	struct kairo_blkg_policy *kpolicy = NULL;
+	struct bio *bio = rq->bio;
+
+	if (!bio)
+		return NULL;
+
+	rcu_read_lock();
+	blkg = blkg_lookup(bio_blkcg(bio), bio->bi_bdev->bd_queue);
+	if (blkg && blkg->pd[KAIRO_BLKG_POLICY])
+		kpolicy = blkg_to_pd(blkg, KAIRO_BLKG_POLICY);
+	rcu_read_unlock();
+
+	/*
+	 * CONCEPTUAL-HOOK: blkg_to_pd returns void*; caller must cast.
+	 * KAIRO_BLKG_POLICY is an enum placeholder (not registered).
+	 */
+	return kpolicy;
+}
+
+/*
+ * kairo_blkg_allow_decode
+ *
+ * Determine whether a decode-class request from this cgroup should
+ * be dispatched immediately.
+ *
+ * Returns true if the cgroup's decode weight is non-zero and its
+ * decode dispatches are within budget relative to other classes.
+ *
+ * CONCEPTUAL-HOOK: Always returns true in this scaffold.
+ */
+static bool __maybe_unused
+kairo_blkg_allow_decode(struct request *rq)
+{
+	struct kairo_blkg_policy *kp = kairo_blkg_policy_from_request(rq);
+
+	if (!kp || kp->decode_weight == 0)
+		return false;
+
+	/* CONCEPTUAL-HOOK: Real budget comparison against sibling
+	 * cgroups would be implemented here.
+	 */
+	return true;
+}
+
+/*
+ * kairo_blkg_throttle_prefetch
+ *
+ * Determine whether a prefetch-class request from this cgroup should
+ * be throttled (deferred) to preserve dispatch capacity for decode.
+ *
+ * CONCEPTUAL-HOOK: Always returns false (do not throttle) in this
+ * scaffold.
+ */
+static bool __maybe_unused
+kairo_blkg_throttle_prefetch(struct request *rq)
+{
+	struct kairo_blkg_policy *kp = kairo_blkg_policy_from_request(rq);
+
+	if (!kp || kp->prefetch_weight == 0)
+		return true;
+
+	/* CONCEPTUAL-HOOK: Real throttle policy would compare
+	 * decode vs prefetch dispatch ratios across cgroups.
+	 */
+	return false;
+}
+
+/*
+ * kairo_blkg_demote_write
+ *
+ * Determine whether a write-class request from this cgroup should be
+ * demoted (deprioritized) under decode pressure.
+ *
+ * CONCEPTUAL-HOOK: Always returns false (no demotion) in this
+ * scaffold.
+ */
+static bool __maybe_unused
+kairo_blkg_demote_write(struct request *rq)
+{
+	struct kairo_blkg_policy *kp = kairo_blkg_policy_from_request(rq);
+
+	if (!kp || kp->write_weight == 0)
+		return true;
+
+	/* CONCEPTUAL-HOOK: Real demotion policy would check
+	 * decode vs write dispatch ratios and target p99 latency.
+	 */
+	return false;
+}
+
+/*
+ * kairo_blkg_account_dispatch
+ *
+ * Account a dispatched request in the cgroup's Kairo stats.
+ *
+ * CONCEPTUAL-HOOK: Increments counter based on io_class, but no
+ * call site is wired.
+ */
+static void __maybe_unused
+kairo_blkg_account_dispatch(struct request *rq)
+{
+	struct kairo_blkg_policy *kp = kairo_blkg_policy_from_request(rq);
+
+	if (!kp)
+		return;
+
+	/* CONCEPTUAL-HOOK: Increment per-class counters;
+	 * no per-blkg_stats pointer allocated yet.
+	 */
+}
+
+/*
+ * cgroup interface files (conceptual)
+ *
+ * These cgroupfs knobs are documented but not implemented.  The
+ * naming and value ranges are candidates for a future real cgroup
+ * controller registration.
+ *
+ *   kairo.policy_class
+ *     Values: default|production_decode|batch_prefill|prefetch|
+ *             eviction|background
+ *     Default: default
+ *
+ *   kairo.target_decode_p99_us
+ *     Per-cgroup target decode p99 latency in microseconds.
+ *     Default: 2000
+ *     Range: 100..100000
+ *
+ *   kairo.decode_weight
+ *     Relative I/O weight for decode-class requests.
+ *     Default: 100
+ *     Range: 0..1000
+ *
+ *   kairo.prefetch_weight
+ *     Relative I/O weight for prefetch-class requests.
+ *     Default: 50
+ *     Range: 0..1000
+ *
+ *   kairo.write_weight
+ *     Relative I/O weight for write-class requests.
+ *     Default: 25
+ *     Range: 0..1000
+ *
+ *   kairo.eviction_weight
+ *     Relative I/O weight for eviction-class requests.
+ *     Default: 10
+ *     Range: 0..1000
+ *
+ *   kairo.allow_recompute_eviction
+ *     Allow eviction of recomputable data from this cgroup.
+ *     Values: 0|1
+ *     Default: 1
+ *
+ * All cgroup knobs require CONFIG_BLK_CGROUP_KAIRO and are not
+ * available in upstream Linux.
+ */
+
+/*
+ * blkcg_policy operations (conceptual)
+ *
+ * LINUX-6.8-CHECK: The blkcg_policy struct requires .pd_alloc_fn,
+ * .pd_free_fn, .pd_init_fn function pointers. The patterns follow
+ * blk-throttle.c.
+ */
+#if 0
+/* CONCEPTUAL-HOOK: Registration deferred */
+static struct blkcg_policy kairo_blkcg_policy = {
+	.pd_alloc_fn	= kairo_blkg_pd_alloc,
+	.pd_free_fn	= kairo_blkg_pd_free,
+	.pd_init_fn	= kairo_blkg_pd_init,
+	.cftypes	= kairo_blkg_cftypes,
+};
+#endif
+
+MODULE_LICENSE("GPL");
+MODULE_AUTHOR("Kairo Authors");
+MODULE_DESCRIPTION("blk-cgroup AI I/O controller scaffold — Kairo RFC/POC");
