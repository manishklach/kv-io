+ */
+
+/*
  * blkcg and blkcg_gq are always compiled in.
  *
  * After blkcg destruction, the policy persists for the life of each
@@ -44,6 +51,30 @@ struct blkcg_policy {
 	unsigned int			pol_id;
 };
 
+/*
+ * Kairo blk-cgroup policy class enum
+ *
+ * Identifies the type of AI I/O workload for a cgroup.  A single
+ * cgroup can contain only one policy class; multi-class cgroups
+ * would require per-request-type sub-accounting.
+ *
+ * LINUX-6.8-CHECK: Enum values are local to Kairo; not part of
+ * the upstream blkcg_policy interface.
+ */
+enum kairo_blkg_policy_class {
+	KAIRO_BLKG_DEFAULT = 0,
+	KAIRO_BLKG_PRODUCTION_DECODE,
+	KAIRO_BLKG_BATCH_PREFILL,
+	KAIRO_BLKG_PREFETCH,
+	KAIRO_BLKG_EVICTION,
+	KAIRO_BLKG_BACKGROUND,
+};
+
+/*
+ * Placeholder for blkcg_policy registration index.
+ * CONCEPTUAL-HOOK: Not registered; value reserved for future use.
+ */
+#define KAIRO_BLKG_POLICY 42
+
 #ifdef CONFIG_BLK_CGROUP
 
 struct blkcg {
@@ -80,8 +111,8 @@ static inline void blkcg_bio_issue_init(struct bio *bio)
 }
 
 #else
-
-/* CONFIG_BLK_CGROUP not enabled — stubs only */
+/* CONFIG_BLK_CGROUP not enabled — no blkcg, no Kairo cgroup policy */
+/* CONFIG_BLK_CGROUP_KAIRO not yet a real Kconfig symbol */
 
 struct blkcg {
 	/* empty when CONFIG_BLK_CGROUP is disabled */
