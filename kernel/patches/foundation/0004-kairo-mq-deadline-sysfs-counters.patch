 	rq = dd_kairo_dispatch_decode_request(dd, now);
 	if (rq) {
 		dd_kairo_note_demotions(dd);
 		goto unlock;
 	}
 
 	rq = dd_kairo_dispatch_prefetch_request(dd, now, now_ns);
 	if (rq) {
 		dd_kairo_note_demotions(dd);
 		goto unlock;
 	}
 
 	rq = dd_dispatch_prio_aged_requests(dd, now);
-	if (rq)
