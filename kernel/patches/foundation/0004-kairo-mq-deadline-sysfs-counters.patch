+static ssize_t deadline_kairo_enable_store(struct elevator_queue *e,
+					   const char *page, size_t count)
+{
+	int data, ret;
+
+	ret = kstrtoint(page, 0, &data);
+	if (ret < 0)
+		return ret;
+	if (data < 0)
+		data = 0;
+	else if (data > 1)
+		data = 1;
+	kairo_enable = data;
+	return count;
+}
+
