+static bool dd_kairo_prefetch_deadline_near(struct request *rq, u64 now_ns)
+{
+	if (!kairo_is_prefetch_read(rq))
+		return false;
+	if (!rq->kairo_hints.deadline_ns)
+		return false;
+
+	return rq->kairo_hints.deadline_ns <=
+	       now_ns + ((u64)kairo_prefetch_deadline_us * NSEC_PER_USEC);
+}
+
+static bool dd_kairo_has_decode_read(struct deadline_data *dd)
+{
+	struct dd_per_prio *per_prio = &dd->per_prio[DD_RT_PRIO];
+	struct request *rq;
+
+	list_for_each_entry(rq, &per_prio->fifo_list[DD_READ], queuelist) {
+		if (kairo_is_decode_read(rq))
+			return true;
+	}
+
+	return false;
+}
+
+static bool dd_kairo_should_demote_prefill(struct deadline_data *dd,
+					   struct request *rq)
+{
+	return kairo_is_prefill_write(rq) &&
+	       (dd_kairo_has_decode_read(dd) ||
+		dd->kairo_prefetch_deadline_hits > dd->kairo_prefetch_dispatches);
+}
+
+static bool dd_kairo_should_demote_evict(struct deadline_data *dd,
+					 struct request *rq)
+{
+	return kairo_is_evict(rq) &&
+	       (dd_kairo_has_decode_read(dd) ||
+		dd->kairo_prefetch_deadline_hits > dd->kairo_prefetch_dispatches);
+}
+
+static void dd_kairo_note_demotions(struct deadline_data *dd)
+{
+	struct request *rq;
+	enum dd_prio prio;
+
+	for (prio = DD_BE_PRIO; prio <= DD_PRIO_MAX; prio++) {
+		struct dd_per_prio *per_prio = &dd->per_prio[prio];
+
+		list_for_each_entry(rq, &per_prio->fifo_list[DD_WRITE], queuelist) {
+			if (kairo_is_prefill_write(rq)) {
+				dd->kairo_prefill_demotions++;
+				break;
+			}
+			if (kairo_is_evict(rq)) {
+				dd->kairo_evict_demotions++;
+				break;
+			}
+		}
+	}
+}
+
 static struct request *dd_kairo_dispatch_decode_request(struct deadline_data *dd,
 							unsigned long latest_start)
 {
@@ -610,12 +682,56 @@ static struct request *dd_kairo_dispatch_decode_request(struct deadline_data *dd
 		deadline_move_request(dd, per_prio, rq);
 		dd->kairo_decode_budget_used++;
 		dd->kairo_decode_dispatches++;
+		dd->kairo_prefetch_budget_used = 0;
 		return dd_kairo_finalize_request(dd, rq, DD_READ);
 	}
 
 	return NULL;
 }
 
+static struct request *dd_kairo_dispatch_prefetch_request(struct deadline_data *dd,
+							  unsigned long latest_start,
+							  u64 now_ns)
+{
+	struct dd_per_prio *per_prio = &dd->per_prio[DD_RT_PRIO];
+	struct request *rq;
+
+	lockdep_assert_held(&dd->lock);
+
+	if (dd_kairo_has_decode_read(dd))
+		return NULL;
+
+	list_for_each_entry(rq, &per_prio->fifo_list[DD_READ], queuelist) {
+		if (!kairo_is_prefetch_read(rq))
+			continue;
+		if (started_after(dd, rq, latest_start))
+			return NULL;
+
+		if (dd_kairo_prefetch_deadline_near(rq, now_ns)) {
+			dd->kairo_prefetch_dispatches++;
+			dd->kairo_prefetch_deadline_hits++;
+			dd->last_dir = DD_READ;
+			dd->batching = 1;
+			deadline_move_request(dd, per_prio, rq);
+			return dd_kairo_finalize_request(dd, rq, DD_READ);
+		}
+
+		if (dd->kairo_prefetch_budget_used < kairo_prefetch_budget) {
+			dd->kairo_prefetch_budget_used++;
+			dd->kairo_prefetch_dispatches++;
+			dd->last_dir = DD_READ;
+			dd->batching = 1;
+			deadline_move_request(dd, per_prio, rq);
+			return dd_kairo_finalize_request(dd, rq, DD_READ);
+		}
+
+		dd->kairo_prefetch_budget_skips++;
+		return NULL;
+	}
+
+	return NULL;
+}
