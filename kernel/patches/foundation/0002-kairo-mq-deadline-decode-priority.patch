diff --git a/block/mq-deadline.c b/block/mq-deadline.c
index 02a916b..82a979d 100755
--- a/block/mq-deadline.c
+++ b/block/mq-deadline.c
@@ -37,6 +37,8 @@ static const int prio_aging_expire = 10 * HZ;
 static const int writes_starved = 2;    /* max times reads can starve a write */
 static const int fifo_batch = 16;       /* # of sequential requests treated as one
 				     by the above parameters. For throughput. */
+static bool kairo_enable = true;
+static unsigned int kairo_decode_budget = 32;
 
 enum dd_data_dir {
 	DD_READ		= READ,
@@ -90,6 +92,10 @@ struct deadline_data {
 	enum dd_data_dir last_dir;
 	unsigned int batching;		/* number of sequential requests made */
 	unsigned int starved;		/* times reads have starved writes */
+	u64 kairo_decode_dispatches;
+	u64 kairo_normal_dispatches;
+	u64 kairo_starvation_escapes;
+	unsigned int kairo_decode_budget_used;
 
 	/*
 	 * settings that change how the i/o scheduler behaves
@@ -557,6 +563,59 @@ done:
 	return rq;
 }
 
+static struct request *dd_kairo_finalize_request(struct deadline_data *dd,
+						 struct request *rq,
+						 enum dd_data_dir data_dir)
+{
+	const u8 ioprio_class = dd_rq_ioclass(rq);
+	const enum dd_prio prio = ioprio_class_to_prio[ioprio_class];
+
+	dd->per_prio[prio].latest_pos[data_dir] = blk_rq_pos(rq);
+	dd->per_prio[prio].stats.dispatched++;
+	blk_req_zone_write_lock(rq);
+	rq->rq_flags |= RQF_STARTED;
+	return rq;
+}
+
+static struct request *dd_kairo_dispatch_decode_request(struct deadline_data *dd,
+							unsigned long latest_start)
+{
+	struct dd_per_prio *per_prio = &dd->per_prio[DD_RT_PRIO];
+	struct request *rq;
+
+	lockdep_assert_held(&dd->lock);
+
+	if (!kairo_enable || kairo_decode_budget <= 0)
+		return NULL;
+
+	if (dd->kairo_decode_budget_used >= kairo_decode_budget)
+		return NULL;
+
+	list_for_each_entry(rq, &per_prio->fifo_list[DD_READ], queuelist) {
+		if (!kairo_is_decode_read(rq))
+			continue;
+		if (started_after(dd, rq, latest_start))
+			return NULL;
+
+		/*
+		 * Safe decode bias:
+		 * scan the existing read FIFO while holding dd->lock, then
+		 * consume the request through deadline_move_request() so the
+		 * normal mq-deadline remove path preserves list/rbtree
+		 * invariants. Final dispatch bookkeeping mirrors the tail of
+		 * __dd_dispatch_request().
+		 */
+		dd->last_dir = DD_READ;
+		dd->batching = 1;
+		deadline_move_request(dd, per_prio, rq);
+		dd->kairo_decode_budget_used++;
+		dd->kairo_decode_dispatches++;
+		return dd_kairo_finalize_request(dd, rq, DD_READ);
+	}
+
+	return NULL;
+}
+
 /*
  * Check whether there are any requests with priority other than DD_RT_PRIO
  * that were inserted more than prio_aging_expire jiffies ago.
@@ -601,6 +660,10 @@ static struct request *dd_dispatch_request(struct blk_mq_hw_ctx *hctx)
 	enum dd_prio prio;
 
 	spin_lock(&dd->lock);
+	rq = dd_kairo_dispatch_decode_request(dd, now);
+	if (rq)
+		goto unlock;
+
 	rq = dd_dispatch_prio_aged_requests(dd, now);
 	if (rq)
 		goto unlock;
@@ -615,6 +678,14 @@ static struct request *dd_dispatch_request(struct blk_mq_hw_ctx *hctx)
 			break;
 	}
 
+	if (rq) {
+		dd->kairo_decode_budget_used = 0;
+		dd->kairo_normal_dispatches++;
+		if (prio != DD_RT_PRIO && dd_queued(dd, DD_RT_PRIO) &&
+		    op_is_write(req_op(rq)))
+			dd->kairo_starvation_escapes++;
+	}
+
 unlock:
 	spin_unlock(&dd->lock);
 
