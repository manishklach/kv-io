+ * struct kairo_kv_region_hint region;
+ * if (req->ctx->kairo_kv_regions &&
+ *     kairo_lookup_kv_region(req, &region))
+ *     kairo_apply_kv_region_hint(rq, &region);
+ */
+
+/* Example conceptual call site in block/blk-mq.c blk_mq_rq_ctx_init():
