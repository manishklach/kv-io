From: Kairo Authors <kairo@research>
Date: Wed Jun 24 18:00:00 2026 +0000
Subject: [RFC/POC] 0027: io_uring KV region hints

RFC/POC — Not for LKML submission.

Add a conceptual io_uring KV region hint scaffold that models how AI
runtimes can tag registered buffers or file regions as KV-cache regions
with type, lifetime, and recompute semantics.

AI runtimes (vLLM, TensorRT-LLM, SGLang) manage KV-cache memory in
explicit regions — decode cache, session cache, model cache, prefetch
cache, recomputable cache.  Today this memory topology is invisible to
the kernel storage stack.

Per-request hints (io_class, semantic_mode) are necessary but not
sufficient: they repeat the same metadata on every I/O.  A region-level
interface lets the runtime register KV region properties once, and the
kernel infers per-request semantics from the buffer or file region.

This patch adds:

  enum kairo_kv_region_type
    KAIRO_KV_REGION_NONE
    KAIRO_KV_REGION_DECODE_CACHE
    KAIRO_KV_REGION_PREFETCH_CACHE
    KAIRO_KV_REGION_SESSION_CACHE
    KAIRO_KV_REGION_MODEL_CACHE
    KAIRO_KV_REGION_RECOMPUTABLE_CACHE

  struct kairo_kv_region_hint
    region_id, type, model_id, session_id,
    file_offset, length, lifetime_class, recompute_ok

Conceptual hooks:

  kairo_request_has_kv_region(struct request *rq)
  kairo_apply_kv_region_hint(struct request *rq,
                             const struct kairo_kv_region_hint *hint)

LINUX-6.8-CHECK:
  io_uring/io_uring.c:       io_kiocb, io_issue_sqe
  io_uring/rw.c:             io_rw, io_read, io_write
  io_uring/opdef.c:          opdef registration table
  include/uapi/linux/io_uring.h: IORING_REGISTER_BUFFERS, IORING_REGISTER_FILES

Signed-off-by: Kairo Authors <kairo@research>
---
 include/linux/blk-mq.h       |  50 +++++++++++++++++
 include/uapi/linux/io_uring.h |  11 ++++
 block/blk-mq.c               |  35 ++++++++++++
 3 files changed, 96 insertions(+)

diff --git a/include/linux/blk-mq.h b/include/linux/blk-mq.h
index b7c8d9e..e9f0a1b 100755
--- a/include/linux/blk-mq.h
+++ b/include/linux/blk-mq.h
@@ -25,6 +25,56 @@
 #include <linux/sbitmap.h>
 
 /*
+ * Kairo KV region hint types
+ *
+ * Identifies the type of KV-cache region that a registered buffer or
+ * file region belongs to.  The runtime sets this once at region
+ * registration time; the kernel infers per-request semantics from the
+ * region metadata.
+ *
+ * CONCEPTUAL-HOOK: These enums are defined but no io_uring registration
+ * path consumes them.
+ */
+enum kairo_kv_region_type {
+	KAIRO_KV_REGION_NONE = 0,
+	KAIRO_KV_REGION_DECODE_CACHE,
+	KAIRO_KV_REGION_PREFETCH_CACHE,
+	KAIRO_KV_REGION_SESSION_CACHE,
+	KAIRO_KV_REGION_MODEL_CACHE,
+	KAIRO_KV_REGION_RECOMPUTABLE_CACHE,
+};
+
+/*
+ * struct kairo_kv_region_hint
+ *
+ * Describes a KV-cache region in terms of file offset, length, type,
+ * model/session affinity, lifetime class, and recompute semantics.
+ *
+ * A single region hint covers a contiguous file extent.  Multiple
+ * regions can be registered covering different KV-cache types.
+ */
+struct kairo_kv_region_hint {
+	u32 region_id;
+	enum kairo_kv_region_type type;
+	u32 model_id;
+	u32 session_id;
+	u64 file_offset;
+	u64 length;
+	u32 lifetime_class;
+	bool recompute_ok;
+};
+
+/*
+ * Inline helpers for KV region hint inspection and application.
+ *
+ * kairo_request_has_kv_region: check whether a request originates from
+ *   a KV-cache region.
+ *
+ * kairo_apply_kv_region_hint: apply region-level metadata to a request's
+ *   Kairo hints (io_class, model/session, lifetime, recompute).
+ *
+ * CONCEPTUAL-HOOK: Both helpers are defined but not called from any
+ * dispatch or io_uring completion path.
+ */
+
+static inline bool __maybe_unused
+kairo_request_has_kv_region(struct request *rq)
+{
+	/*
+	 * CONCEPTUAL-HOOK: Check rq->bio or rq->kairo_hints for a
+	 * KV region identifier set by io_uring registration.
+	 *
+	 * LINUX-6.8-CHECK: io_uring does not currently set per-request
+	 * region metadata on struct request.
+	 */
+	return false;
+}
+
+static inline void __maybe_unused
+kairo_apply_kv_region_hint(struct request *rq,
+			   const struct kairo_kv_region_hint *hint)
+{
+	/*
+	 * CONCEPTUAL-HOOK: Populate rq->kairo_hints fields from the
+	 * region hint:
+	 *   - Set io_class based on region type
+	 *   - Set model_id / session_id from hint
+	 *   - Set lifetime_class from hint
+	 *   - Set recompute_ok from hint
+	 *
+	 * LINUX-6.8-CHECK: rq does not have a kairo_hints field in
+	 * upstream 6.8; requires Kairo patch 0002.
+	 */
+	(void)rq;
+	(void)hint;
+}
+
+/*
  * Flags used in .blk_alloc_cache_ctx
  */
 #define BLK_MQ_CREATE_IRQ_DISPATCH_MASK	0
diff --git a/include/uapi/linux/io_uring.h b/include/uapi/linux/io_uring.h
index 3d4e5f6..a7b8c9d 100755
--- a/include/uapi/linux/io_uring.h
+++ b/include/uapi/linux/io_uring.h
@@ -25,6 +25,17 @@
 
 /*
+ * Kairo KV region hint registration
+ *
+ * Conceptual io_uring registration opcodes for tagging registered
+ * buffers or file regions as KV-cache regions.
+ *
+ * CONCEPTUAL-HOOK: These opcodes are reserved for future use.
+ * Not implemented in any io_uring registration path.
+ */
+#define IORING_REGISTER_KAIRO_KV_REGION	42
+#define IORING_REGISTER_KAIRO_KV_REGIONS	43
