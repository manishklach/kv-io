  * by the kernel build to generate the uapi header.  Do not remove.
  */
diff --git a/block/blk-mq.c b/block/blk-mq.c
index f1a2b3c..c4d5e6f 100755
--- a/block/blk-mq.c
+++ b/block/blk-mq.c
@@ -25,6 +25,41 @@
 #include "blk-mq.h"
 
 /*
