+static void dd_kairo_account_merge(struct deadline_data *dd, struct request *rq)
+{
+	u32 flags = rq->kairo_hints.flags;
+	unsigned int sectors;
+	u64 size_kb;
+
+	if (flags & KAIRO_HINT_MERGE_ATTEMPTED) {
+		dd->kairo_merge_attempts++;
+		if (flags & KAIRO_HINT_MERGE_SUCCESS) {
+			dd->kairo_merge_successes++;
+			if (kairo_is_decode_read(rq))
+				dd->kairo_decode_merge_successes++;
+			else if (kairo_is_prefetch_read(rq))
+				dd->kairo_prefetch_merge_successes++;
+		} else {
+			dd->kairo_merge_rejects++;
+		}
+		if (kairo_is_decode_read(rq))
+			dd->kairo_decode_merge_attempts++;
+		else if (kairo_is_prefetch_read(rq))
+			dd->kairo_prefetch_merge_attempts++;
+	}
+
+	/* classify request size */
+	sectors = blk_rq_sectors(rq);
+	size_kb = (u64)sectors << 9;
+
+	if (kairo_is_decode_read(rq)) {
+		if (size_kb >= kairo_large_read_kb)
+			dd->kairo_large_decode_reads++;
+		else
+			dd->kairo_small_decode_reads++;
+	} else if (kairo_is_prefetch_read(rq)) {
+		if (size_kb >= kairo_large_read_kb)
+			dd->kairo_large_prefetch_reads++;
+		else
+			dd->kairo_small_prefetch_reads++;
+	}
+}
+
+static void dd_kairo_account_size_histogram(struct deadline_data *dd,
+					     struct request *rq)
+{
+	unsigned int sectors = blk_rq_sectors(rq);
+	u64 *bucket;
+
+	if (kairo_is_decode_read(rq)) {
+		if (sectors <= 8)
+			bucket = &dd->kairo_decode_read_4k;
+		else if (sectors <= 32)
+			bucket = &dd->kairo_decode_read_16k;
+		else if (sectors <= 128)
+			bucket = &dd->kairo_decode_read_64k;
+		else if (sectors <= 512)
+			bucket = &dd->kairo_decode_read_256k;
+		else if (sectors <= 2048)
+			bucket = &dd->kairo_decode_read_1m;
+		else if (sectors <= 8192)
+			bucket = &dd->kairo_decode_read_4m;
+		else
+			bucket = &dd->kairo_decode_read_gt4m;
+		(*bucket)++;
+	} else if (kairo_is_prefetch_read(rq)) {
+		if (sectors <= 8)
+			bucket = &dd->kairo_prefetch_read_4k;
+		else if (sectors <= 32)
+			bucket = &dd->kairo_prefetch_read_16k;
+		else if (sectors <= 128)
+			bucket = &dd->kairo_prefetch_read_64k;
+		else if (sectors <= 512)
+			bucket = &dd->kairo_prefetch_read_256k;
+		else if (sectors <= 2048)
+			bucket = &dd->kairo_prefetch_read_1m;
+		else if (sectors <= 8192)
+			bucket = &dd->kairo_prefetch_read_4m;
+		else
+			bucket = &dd->kairo_prefetch_read_gt4m;
+		(*bucket)++;
+	}
+}
+
+static void dd_kairo_account_dispatch(struct deadline_data *dd, struct request *rq)
+{
+	dd_kairo_account_merge(dd, rq);
+	dd_kairo_account_size_histogram(dd, rq);
+
+	switch (rq->kairo_hints.io_class) {
+	case KAIRO_IO_DECODE_READ:
+		dd->kairo_decode_dispatches++;
+		dd->kairo_hinted_requests++;
+		break;
+	case KAIRO_IO_PREFETCH_READ:
+		dd->kairo_prefetch_dispatches++;
+		dd->kairo_hinted_requests++;
+		break;
+	case KAIRO_IO_PREFILL_WRITE:
+		dd->kairo_prefill_dispatches++;
+		dd->kairo_hinted_requests++;
+		break;
+	case KAIRO_IO_EVICT:
+		dd->kairo_evict_dispatches++;
+		dd->kairo_hinted_requests++;
+		break;
+	case KAIRO_IO_NORMAL:
+		dd->kairo_normal_dispatches++;
+		dd->kairo_unhinted_requests++;
+		break;
+	default:
+		dd->kairo_unhinted_requests++;
+		break;
+	}
+}
@@
+static ssize_t kairo_large_read_kb_show(struct elevator_queue *e, char *page)
+{
+	return sysfs_emit(page, "%u\n", kairo_large_read_kb);
+}
