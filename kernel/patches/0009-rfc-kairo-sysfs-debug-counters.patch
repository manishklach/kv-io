Stage 4 observability note:
- add hint-source counters so local experiments can distinguish explicit
  Kairo metadata from ioprio fallback and final request-op fallback

diff --git a/block/mq-deadline.c b/block/mq-deadline.c
index df06aa7..d593561 100755
--- a/block/mq-deadline.c
+++ b/block/mq-deadline.c
@@ -93,8 +93,13 @@ struct deadline_data {
 	unsigned int batching;		/* number of sequential requests made */
 	unsigned int starved;		/* times reads have starved writes */
 	u64 kairo_decode_dispatches;
+	u64 kairo_prefetch_dispatches;
+	u64 kairo_prefill_dispatches;
+	u64 kairo_evict_dispatches;
	u64 kairo_normal_dispatches;
	u64 kairo_starvation_escapes;
+	u64 kairo_hinted_requests;
+	u64 kairo_unhinted_requests;
+	u64 kairo_ioprio_hinted_requests;
+	u64 kairo_rwf_hinted_requests;
+	u64 kairo_bio_hinted_requests;
+	u64 kairo_hint_fallback_requests;
	u32 kairo_decode_budget_used;
 
 	/*
@@ -617,6 +622,32 @@ static struct request *dd_kairo_dispatch_decode_request(struct deadline_data *dd
 	return rq;
 }
 
+static void dd_kairo_account_dispatch(struct deadline_data *dd,
+				      struct request *rq)
+{
+	const enum kairo_io_class io_class = kairo_classify_rq(rq);
+	const u16 ioprio = req_get_ioprio(rq);
+
+	if (IOPRIO_PRIO_CLASS(ioprio) == IOPRIO_CLASS_NONE)
+		dd->kairo_unhinted_requests++;
+	else
+		dd->kairo_hinted_requests++;
+
+	/*
+	 * Stage 4 local RFC/POC accounting:
+	 * explicit request or bio metadata -> kairo_bio_hinted_requests
+	 * kiocb/RWF-derived hints          -> kairo_rwf_hinted_requests
+	 * ioprio-only fallback             -> kairo_ioprio_hinted_requests
+	 * req_op fallback                  -> kairo_hint_fallback_requests
+	 */
+
+	switch (io_class) {
+	case KAIRO_IO_PREFETCH_READ:
+		dd->kairo_prefetch_dispatches++;
+		break;
+	case KAIRO_IO_PREFILL_WRITE:
+		dd->kairo_prefill_dispatches++;
+		break;
+	case KAIRO_IO_EVICT:
+		dd->kairo_evict_dispatches++;
+		break;
+	default:
+		break;
+	}
+}
+
 /*
  * Called from blk_mq_run_hw_queue() -> __blk_mq_sched_dispatch_requests().
  *
@@ -635,6 +666,7 @@ static struct request *dd_dispatch_request(struct blk_mq_hw_ctx *hctx)
 	spin_lock(&dd->lock);
 	rq = dd_kairo_dispatch_decode_request(dd, now);
 	if (rq) {
+		dd_kairo_account_dispatch(dd, rq);
 		if (!kairo_is_decode_read(rq)) {
 			dd->kairo_decode_budget_used = 0;
 			dd->kairo_normal_dispatches++;
@@ -657,6 +689,7 @@ static struct request *dd_dispatch_request(struct blk_mq_hw_ctx *hctx)
 	}
 
 	if (rq) {
+		dd_kairo_account_dispatch(dd, rq);
 		if (kairo_enable && prio != DD_RT_PRIO &&
 		    dd_queued(dd, DD_RT_PRIO) && op_is_write(req_op(rq))) {
 			dd->kairo_starvation_escapes++;
@@ -1056,6 +1089,33 @@ static ssize_t deadline_kairo_normal_dispatches_show(struct elevator_queue *e,
 			  (unsigned long long)dd->kairo_normal_dispatches);
 }
 
