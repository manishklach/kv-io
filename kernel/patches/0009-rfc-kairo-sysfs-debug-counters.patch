+}
+
+static ssize_t deadline_kairo_evict_dispatches_show(struct elevator_queue *e,
+						    char *page)
+{
+	struct deadline_data *dd = e->elevator_data;
+
+	return sysfs_emit(page, "%llu\n",
+			  (unsigned long long)dd->kairo_evict_dispatches);
+}
+
 static ssize_t deadline_kairo_starvation_escapes_show(struct elevator_queue *e,
 						      char *page)
 {
@@ -1065,6 +1125,24 @@ static ssize_t deadline_kairo_starvation_escapes_show(struct elevator_queue *e,
 			  (unsigned long long)dd->kairo_starvation_escapes);
 }
 
+static ssize_t deadline_kairo_hinted_requests_show(struct elevator_queue *e,
+						   char *page)
+{
+	struct deadline_data *dd = e->elevator_data;
+
+	return sysfs_emit(page, "%llu\n",
+			  (unsigned long long)dd->kairo_hinted_requests);
+}
+
+static ssize_t deadline_kairo_unhinted_requests_show(struct elevator_queue *e,
+						     char *page)
+{
+	struct deadline_data *dd = e->elevator_data;
+
+	return sysfs_emit(page, "%llu\n",
+			  (unsigned long long)dd->kairo_unhinted_requests);
+}
+
+static ssize_t deadline_kairo_ioprio_hinted_requests_show(struct elevator_queue *e,
+							  char *page)
+{
+	struct deadline_data *dd = e->elevator_data;
+
+	return sysfs_emit(page, "%llu\n",
+			  (unsigned long long)dd->kairo_ioprio_hinted_requests);
+}
+
+static ssize_t deadline_kairo_rwf_hinted_requests_show(struct elevator_queue *e,
+						       char *page)
+{
+	struct deadline_data *dd = e->elevator_data;
+
+	return sysfs_emit(page, "%llu\n",
+			  (unsigned long long)dd->kairo_rwf_hinted_requests);
+}
+
+static ssize_t deadline_kairo_bio_hinted_requests_show(struct elevator_queue *e,
+						       char *page)
+{
+	struct deadline_data *dd = e->elevator_data;
+
+	return sysfs_emit(page, "%llu\n",
+			  (unsigned long long)dd->kairo_bio_hinted_requests);
+}
+
+static ssize_t deadline_kairo_hint_fallback_requests_show(struct elevator_queue *e,
+							  char *page)
+{
+	struct deadline_data *dd = e->elevator_data;
+
+	return sysfs_emit(page, "%llu\n",
+			  (unsigned long long)dd->kairo_hint_fallback_requests);
+}
+
 #define STORE_FUNCTION(__FUNC, __PTR, MIN, MAX, __CONV)			\
 static ssize_t __FUNC(struct elevator_queue *e, const char *page, size_t count)	\
 {									\
@@ -1114,8 +1192,13 @@ static struct elv_fs_entry deadline_attrs[] = {
 	DD_ATTR(kairo_enable),
 	DD_ATTR(kairo_decode_budget),
 	DD_RO_ATTR(kairo_decode_dispatches),
+	DD_RO_ATTR(kairo_prefetch_dispatches),
+	DD_RO_ATTR(kairo_prefill_dispatches),
+	DD_RO_ATTR(kairo_evict_dispatches),
 	DD_RO_ATTR(kairo_normal_dispatches),
 	DD_RO_ATTR(kairo_starvation_escapes),
+	DD_RO_ATTR(kairo_hinted_requests),
+	DD_RO_ATTR(kairo_unhinted_requests),
+	DD_RO_ATTR(kairo_ioprio_hinted_requests),
+	DD_RO_ATTR(kairo_rwf_hinted_requests),
