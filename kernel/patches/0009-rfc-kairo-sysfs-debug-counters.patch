+}
+
+static ssize_t kairo_large_read_kb_store(struct elevator_queue *e,
+					  const char *page, size_t count)
+{
+	int data, ret;
+
+	ret = kstrtoint(page, 0, &data);
+	if (ret < 0)
+		return ret;
+	if (data < 4)
+		data = 4;
+	kairo_large_read_kb = data;
+	return count;
+}
+
+static ssize_t kairo_merge_bias_enable_store(struct elevator_queue *e,
+					      const char *page, size_t count)
+{
+	int data, ret;
+
+	ret = kstrtoint(page, 0, &data);
+	if (ret < 0)
+		return ret;
+	kairo_merge_bias_enable = !!data;
+	return count;
+}
