+							char *page)
+{
+	struct deadline_data *dd = e->elevator_data;
+
+	return sysfs_emit(page, "%llu\n",
+			  (unsigned long long)dd->kairo_prefetch_dispatches);
+}
+
+static ssize_t deadline_kairo_prefill_dispatches_show(struct elevator_queue *e,
