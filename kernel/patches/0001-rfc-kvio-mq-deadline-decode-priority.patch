From 9e4d9cf9d8300000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: KV-IO POC <kvio-poc@local>
Date: Sat, 21 Jun 2026 12:00:00 -0700
Subject: [RFC/POC PATCH] mq-deadline: prioritize KV-IO decode reads

Local RFC/POC patch for KV-IO.

This patch adds a small decode-first fast path to mq-deadline using
existing request ioprio metadata as a temporary classification mechanism.
The local intent is to improve p99 decode-read latency under mixed write
pressure without rewriting the scheduler.

Classification used by this POC:
- RT class, prio 0, read  => decode
- RT class, prio 1, read  => prefetch
- BE class, prio 7, write => prefill write

The patch is intentionally narrow:
- add kvio_enable and a decode batch limit
- identify decode reads via req_get_ioprio()
- dispatch decode reads from the RT bucket before normal dispatch
- fall back to existing mq-deadline behavior otherwise

diff --git a/block/mq-deadline.c b/block/mq-deadline.c
index 111111111111..222222222222 100644
--- a/block/mq-deadline.c
+++ b/block/mq-deadline.c
@@ -23,6 +23,11 @@
  static const int writes_starved = 2;    /* max times reads can starve a write */
  static const int fifo_batch = 16;       /* # of sequential requests treated as one
 				     by the above parameters. For throughput. */
+static bool kvio_enable = true;
+module_param_named(kvio_enable, kvio_enable, bool, 0644);
+static unsigned int kvio_decode_batch = 8;
+module_param_named(kvio_decode_batch, kvio_decode_batch, uint, 0644);
+
 
  enum dd_data_dir {
  	DD_READ		= READ,
@@ -95,6 +100,11 @@ struct deadline_data {
 	spinlock_t lock;
 	spinlock_t zone_lock;
+
+	u64 kvio_decode_dispatches;
+	u64 kvio_normal_dispatches;
+	u64 kvio_write_starvation_escapes;
+	unsigned int kvio_decode_batching;
  };
 
 /* Maps an I/O priority class to a deadline scheduler priority. */
@@ -126,6 +136,33 @@ static u8 dd_rq_ioclass(struct request *rq)
 	return IOPRIO_PRIO_CLASS(req_get_ioprio(rq));
 }
 
+static bool dd_kvio_is_decode_read(struct request *rq)
+{
+	unsigned short ioprio = req_get_ioprio(rq);
+
+	return rq_data_dir(rq) == READ &&
+	       IOPRIO_PRIO_CLASS(ioprio) == IOPRIO_CLASS_RT &&
+	       IOPRIO_PRIO_DATA(ioprio) == 0;
+}
+
+static bool dd_kvio_is_prefetch_read(struct request *rq)
+{
+	unsigned short ioprio = req_get_ioprio(rq);
+
+	return rq_data_dir(rq) == READ &&
+	       IOPRIO_PRIO_CLASS(ioprio) == IOPRIO_CLASS_RT &&
+	       IOPRIO_PRIO_DATA(ioprio) == 1;
+}
+
+static bool dd_kvio_is_prefill_write(struct request *rq)
+{
+	unsigned short ioprio = req_get_ioprio(rq);
+
+	return rq_data_dir(rq) == WRITE &&
+	       IOPRIO_PRIO_CLASS(ioprio) == IOPRIO_CLASS_BE &&
+	       IOPRIO_PRIO_DATA(ioprio) == 7;
+}
+
 /*
  * get the request before `rq' in sector-sorted order
  */
@@ -564,6 +601,55 @@ static struct request *dd_dispatch_prio_aged_requests(struct deadline_data *dd,
 	return NULL;
 }
 
+static struct request *dd_kvio_dispatch_decode_request(struct deadline_data *dd,
+						      unsigned long latest_start)
+{
+	struct dd_per_prio *per_prio = &dd->per_prio[DD_RT_PRIO];
+	struct request *rq;
+
+	lockdep_assert_held(&dd->lock);
+
+	if (!kvio_enable || dd->kvio_decode_batching >= kvio_decode_batch)
+		return NULL;
+
+	list_for_each_entry(rq, &per_prio->dispatch, queuelist) {
+		if (!dd_kvio_is_decode_read(rq))
+			continue;
+		if (started_after(dd, rq, latest_start))
+			return NULL;
+		list_del_init(&rq->queuelist);
+		goto done;
+	}
+
+	list_for_each_entry(rq, &per_prio->fifo_list[DD_READ], queuelist) {
+		if (!dd_kvio_is_decode_read(rq))
+			continue;
+		if (started_after(dd, rq, latest_start))
+			return NULL;
+		dd->last_dir = DD_READ;
+		dd->batching = 0;
+		dd->batching++;
+		deadline_move_request(dd, per_prio, rq);
+		goto done;
+	}
+
+	return NULL;
+
+done:
+	dd->kvio_decode_batching++;
+	dd->kvio_decode_dispatches++;
+	per_prio->latest_pos[DD_READ] = blk_rq_pos(rq);
+	per_prio->stats.dispatched++;
+	blk_req_zone_write_lock(rq);
+	rq->rq_flags |= RQF_STARTED;
+	return rq;
+}
+
 /*
  * Called from blk_mq_run_hw_queue() -> __blk_mq_sched_dispatch_requests().
  *
@@ -599,6 +685,13 @@ static struct request *dd_dispatch_request(struct blk_mq_hw_ctx *hctx)
 	struct request *rq;
 	enum dd_prio prio;
 
+	if (kvio_enable) {
+		spin_lock(&dd->lock);
+		rq = dd_kvio_dispatch_decode_request(dd, now);
+		spin_unlock(&dd->lock);
+		if (rq)
+			return rq;
+	}
+
 	spin_lock(&dd->lock);
 	rq = dd_dispatch_prio_aged_requests(dd, now);
 	if (rq)
@@ -612,8 +705,20 @@ static struct request *dd_dispatch_request(struct blk_mq_hw_ctx *hctx)
 	for (prio = 0; prio <= DD_PRIO_MAX; prio++) {
 		rq = __dd_dispatch_request(dd, &dd->per_prio[prio], now);
 		if (rq || dd_queued(dd, prio))
+			break;
+	}
+
+	if (kvio_enable) {
+		if (rq && !dd_kvio_is_decode_read(rq)) {
+			dd->kvio_decode_batching = 0;
+			dd->kvio_normal_dispatches++;
+			if (rq_data_dir(rq) == WRITE &&
+			    dd_queued(dd, DD_RT_PRIO))
+				dd->kvio_write_starvation_escapes++;
+		} else if (!rq) {
+			dd->kvio_decode_batching = 0;
+		}
 	}
 
 unlock:
 	spin_unlock(&dd->lock);
