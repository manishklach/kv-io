From 1010101010100000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Kairo POC <kairo-poc@local>
Date: Sun, 21 Jun 2026 22:00:00 -0700
Subject: [RFC/POC PATCH 10/9] Kairo kernel tracepoint observability scaffold

RFC/POC ONLY:
This patch adds Kairo tracepoint scaffolding for request lifecycle
observability. Tracepoint names and payloads are not stable ABI.
The goal is local kernel research and benchmark validation.

Subsystem touched:
- `include/trace/events/kairo.h` (new)
- `block/blk-mq.c`
- `block/mq-deadline.c`
- `block/blk-merge.c`
- `drivers/nvme/host/core.c`
- `include/linux/blk-mq.h`
- `include/linux/blk_types.h`

Kairo concept:
- tracepoints for each request lifecycle stage: classification, scheduler
  decision, dispatch, demotion, merge, semantic flags, placement metadata,
  backend mapping
- RFC/POC tracepoint definitions only; no stable tracing ABI
- scripts/bpftrace/ scripts for analysis with patched kernel

Stage 8 relation:
- connects Stage 1 (classification) through Stage 7 (backend mapping)
  into a unified tracepoint layer
- tracepoints match benchmark output fields for cross-validation

Still to validate:
- whether tracepoint overhead is acceptable in the hot dispatch path
- whether all tracepoints produce useful signal for kernel developers
- whether bpftrace scripts correctly parse tracepoint output

diff --git a/include/trace/events/kairo.h b/include/trace/events/kairo.h
new file mode 100644
index 0000000..e69de29
--- /dev/null
+++ b/include/trace/events/kairo.h
@@ -0,0 +1,350 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+/*
+ * RFC/POC: Kairo tracepoint definitions.
+ *
+ * These tracepoints instrument the Kairo request lifecycle for kernel
+ * observability via ftrace, perf, or bpftrace.
+ *
+ * COMPILE-RISK: MEDIUM. The TRACE_EVENT macros follow standard kernel
+ * conventions. However, the exact payload structs and field types may
+ * need adjustment for the target kernel version (Linux 6.8.x).
+ *
+ * Not stable ABI. For local kernel research only.
+ */
+
+#undef TRACE_SYSTEM
+#define TRACE_SYSTEM kairo
+
+#if !defined(_TRACE_KAIRO_H) || defined(TRACE_HEADER_MULTI_READ)
+#define _TRACE_KAIRO_H
+
+#include <linux/tracepoint.h>
+#include <linux/types.h>
+
+/*
+ * Helper enums for tracepoint payload fields.
+ *
+ * These mirror Kairo internal classification values.
+ * They are defined here so trace output is self-describing.
+ */
+
+/* kairo_io_class matches enum kairo_io_class from blk_types.h */
+#define KAIRO_TRACE_IO_NONE		0
+#define KAIRO_TRACE_IO_DECODE_READ	1
+#define KAIRO_TRACE_IO_PREFETCH_READ	2
+#define KAIRO_TRACE_IO_PREFILL_WRITE	3
+#define KAIRO_TRACE_IO_EVICT		4
+#define KAIRO_TRACE_IO_NORMAL		5
+
+/* kairo_hint_source matches hint source in request metadata */
+#define KAIRO_TRACE_HINT_NONE		0
+#define KAIRO_TRACE_HINT_IOPRIO		1
+#define KAIRO_TRACE_HINT_RWF		2
+#define KAIRO_TRACE_HINT_BOTH		3
+
+/* kairo_scheduler_decision values */
+#define KAIRO_TRACE_DECISION_DISPATCH		0
+#define KAIRO_TRACE_DECISION_DEMOTE_PREFILL	1
+#define KAIRO_TRACE_DECISION_DEMOTE_EVICT	2
+#define KAIRO_TRACE_DECISION_BYPASS		3
+#define KAIRO_TRACE_DECISION_NORMAL		4
+
+/* kairo_backend_class matches enum kairo_backend_class */
+#define KAIRO_TRACE_BACKEND_NONE		0
+#define KAIRO_TRACE_BACKEND_SHORT_LIVED		1
+#define KAIRO_TRACE_BACKEND_SESSION_LOCAL	2
+#define KAIRO_TRACE_BACKEND_MODEL_LOCAL		3
+#define KAIRO_TRACE_BACKEND_RECOMPUTABLE	4
+#define KAIRO_TRACE_BACKEND_PERSISTENT		5
+
+/*
+ * Tracepoint: kairo_request_classified
+ *
+ * Emitted when Kairo classifies a request at the blk-mq layer.
+ * CONCEPTUAL-HOOK: placement depends on where kairo_classify_rq() is
+ * called and whether the request has valid metadata at that point.
+ */
+TRACE_EVENT(kairo_request_classified,
+	TP_PROTO(unsigned int dev, sector_t sector, unsigned int nr_bytes,
+		 unsigned int op, unsigned int ioprio,
+		 unsigned int io_class, unsigned int hint_source,
+		 unsigned int flags),
+
+	TP_ARGS(dev, sector, nr_bytes, op, ioprio, io_class, hint_source,
+		flags),
+
+	TP_STRUCT__entry(
+		__field(unsigned int, dev)
+		__field(sector_t, sector)
+		__field(unsigned int, nr_bytes)
+		__field(unsigned int, op)
+		__field(unsigned int, ioprio)
+		__field(unsigned int, io_class)
+		__field(unsigned int, hint_source)
+		__field(unsigned int, flags)
+	),
+
+	TP_fast_assign(
+		__entry->dev		= dev;
+		__entry->sector		= sector;
+		__entry->nr_bytes	= nr_bytes;
+		__entry->op		= op;
+		__entry->ioprio		= ioprio;
+		__entry->io_class	= io_class;
+		__entry->hint_source	= hint_source;
+		__entry->flags		= flags;
+	),
+
+	TP_printk("dev=%u sector=%llu nr_bytes=%u op=%u ioprio=%u "
+		  "io_class=%u hint_source=%u flags=%u",
+		  __entry->dev, (unsigned long long)__entry->sector,
+		  __entry->nr_bytes, __entry->op, __entry->ioprio,
+		  __entry->io_class, __entry->hint_source, __entry->flags)
+);
+
+/*
+ * Tracepoint: kairo_scheduler_decision
+ *
+ * Emitted when mq-deadline makes a Kairo-aware scheduling decision.
+ * CONCEPTUAL-HOOK: exact call sites depend on mq-deadline internal
+ * dispatch helpers.
+ */
+TRACE_EVENT(kairo_scheduler_decision,
+	TP_PROTO(unsigned int dev, sector_t sector, unsigned int nr_bytes,
+		 unsigned int io_class, unsigned int decision,
+		 unsigned int reason, unsigned int budget_used,
+		 unsigned long long deadline_ns),
+
+	TP_ARGS(dev, sector, nr_bytes, io_class, decision, reason,
+		budget_used, deadline_ns),
+
+	TP_STRUCT__entry(
+		__field(unsigned int, dev)
+		__field(sector_t, sector)
+		__field(unsigned int, nr_bytes)
+		__field(unsigned int, io_class)
+		__field(unsigned int, decision)
+		__field(unsigned int, reason)
+		__field(unsigned int, budget_used)
+		__field(unsigned long long, deadline_ns)
+	),
+
+	TP_fast_assign(
+		__entry->dev		= dev;
+		__entry->sector		= sector;
+		__entry->nr_bytes	= nr_bytes;
+		__entry->io_class	= io_class;
+		__entry->decision	= decision;
+		__entry->reason		= reason;
+		__entry->budget_used	= budget_used;
+		__entry->deadline_ns	= deadline_ns;
+	),
+
+	TP_printk("dev=%u sector=%llu nr_bytes=%u io_class=%u "
+		  "decision=%u reason=%u budget=%u deadline_ns=%llu",
+		  __entry->dev, (unsigned long long)__entry->sector,
+		  __entry->nr_bytes, __entry->io_class, __entry->decision,
+		  __entry->reason, __entry->budget_used,
+		  (unsigned long long)__entry->deadline_ns)
+);
+
+/*
+ * Tracepoint: kairo_decode_dispatch
+ *
+ * Emitted when a decode-critical read is dispatched.
+ * COMPILE-TARGET: call site in dd_kairo_dispatch_decode_request() or
+ * equivalent mq-deadline decode dispatch helper.
+ */
+TRACE_EVENT(kairo_decode_dispatch,
+	TP_PROTO(unsigned int dev, sector_t sector, unsigned int nr_bytes,
+		 unsigned int budget_used, unsigned long long latency_hint_ns),
+
+	TP_ARGS(dev, sector, nr_bytes, budget_used, latency_hint_ns),
+
+	TP_STRUCT__entry(
+		__field(unsigned int, dev)
+		__field(sector_t, sector)
+		__field(unsigned int, nr_bytes)
+		__field(unsigned int, budget_used)
+		__field(unsigned long long, latency_hint_ns)
+	),
+
+	TP_fast_assign(
+		__entry->dev		= dev;
+		__entry->sector		= sector;
+		__entry->nr_bytes	= nr_bytes;
+		__entry->budget_used	= budget_used;
+		__entry->latency_hint_ns = latency_hint_ns;
+	),
+
+	TP_printk("dev=%u sector=%llu nr_bytes=%u budget=%u "
+		  "latency_hint_ns=%llu",
+		  __entry->dev, (unsigned long long)__entry->sector,
+		  __entry->nr_bytes, __entry->budget_used,
+		  (unsigned long long)__entry->latency_hint_ns)
+);
+
+/*
+ * Tracepoint: kairo_prefetch_dispatch
+ *
+ * Emitted when a prefetch read is dispatched.
+ * COMPILE-TARGET: call site in dd_kairo_dispatch_prefetch_request().
+ */
+TRACE_EVENT(kairo_prefetch_dispatch,
+	TP_PROTO(unsigned int dev, sector_t sector, unsigned int nr_bytes,
+		 unsigned int budget_used, unsigned long long deadline_ns,
+		 unsigned int deadline_near),
+
+	TP_ARGS(dev, sector, nr_bytes, budget_used, deadline_ns,
+		deadline_near),
+
+	TP_STRUCT__entry(
+		__field(unsigned int, dev)
+		__field(sector_t, sector)
+		__field(unsigned int, nr_bytes)
+		__field(unsigned int, budget_used)
+		__field(unsigned long long, deadline_ns)
+		__field(unsigned int, deadline_near)
+	),
+
+	TP_fast_assign(
+		__entry->dev		= dev;
+		__entry->sector		= sector;
+		__entry->nr_bytes	= nr_bytes;
+		__entry->budget_used	= budget_used;
+		__entry->deadline_ns	= deadline_ns;
+		__entry->deadline_near	= deadline_near;
+	),
+
+	TP_printk("dev=%u sector=%llu nr_bytes=%u budget=%u "
+		  "deadline_ns=%llu deadline_near=%u",
+		  __entry->dev, (unsigned long long)__entry->sector,
+		  __entry->nr_bytes, __entry->budget_used,
+		  (unsigned long long)__entry->deadline_ns,
+		  __entry->deadline_near)
+);
+
+/*
+ * Tracepoint: kairo_write_demoted
+ *
+ * Emitted when prefill or evict work is demoted behind decode/prefetch.
+ * COMPILE-TARGET: call sites in dd_kairo_should_demote_prefill() and
+ * dd_kairo_should_demote_evict().
+ */
+TRACE_EVENT(kairo_write_demoted,
+	TP_PROTO(unsigned int dev, sector_t sector, unsigned int nr_bytes,
+		 unsigned int io_class, unsigned int reason,
+		 unsigned int starvation_escape),
+
+	TP_ARGS(dev, sector, nr_bytes, io_class, reason, starvation_escape),
+
+	TP_STRUCT__entry(
+		__field(unsigned int, dev)
+		__field(sector_t, sector)
+		__field(unsigned int, nr_bytes)
+		__field(unsigned int, io_class)
+		__field(unsigned int, reason)
+		__field(unsigned int, starvation_escape)
+	),
+
+	TP_fast_assign(
+		__entry->dev		= dev;
+		__entry->sector		= sector;
+		__entry->nr_bytes	= nr_bytes;
+		__entry->io_class	= io_class;
+		__entry->reason		= reason;
+		__entry->starvation_escape = starvation_escape;
+	),
+
+	TP_printk("dev=%u sector=%llu nr_bytes=%u io_class=%u "
+		  "reason=%u starvation_escape=%u",
+		  __entry->dev, (unsigned long long)__entry->sector,
+		  __entry->nr_bytes, __entry->io_class, __entry->reason,
+		  __entry->starvation_escape)
+);
+
+/*
+ * Tracepoint: kairo_merge_decision
+ *
+ * Emitted when Kairo merge/coalescing policy observes or biases a
+ * merge decision.
+ * CONCEPTUAL-HOOK: call site depends on exact merge instrumentation
+ * from Stage 3 (0004 patch).
+ */
+TRACE_EVENT(kairo_merge_decision,
+	TP_PROTO(unsigned int dev, sector_t sector, unsigned int nr_bytes,
+		 unsigned int io_class, unsigned int merge_attempted,
+		 unsigned int merge_success, unsigned int reason),
+
+	TP_ARGS(dev, sector, nr_bytes, io_class, merge_attempted,
+		merge_success, reason),
+
+	TP_STRUCT__entry(
+		__field(unsigned int, dev)
+		__field(sector_t, sector)
+		__field(unsigned int, nr_bytes)
+		__field(unsigned int, io_class)
+		__field(unsigned int, merge_attempted)
+		__field(unsigned int, merge_success)
+		__field(unsigned int, reason)
+	),
+
+	TP_fast_assign(
+		__entry->dev		= dev;
