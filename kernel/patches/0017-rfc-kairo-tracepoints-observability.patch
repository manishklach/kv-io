+		__entry->nr_bytes	= nr_bytes;
+		__entry->io_class	= io_class;
+		__entry->merge_attempted = merge_attempted;
+		__entry->merge_success	= merge_success;
+		__entry->reason		= reason;
+	),
+
+	TP_printk("dev=%u sector=%llu nr_bytes=%u io_class=%u "
+		  "merge_attempted=%u merge_success=%u reason=%u",
+		  __entry->dev, (unsigned long long)__entry->sector,
+		  __entry->nr_bytes, __entry->io_class,
+		  __entry->merge_attempted, __entry->merge_success,
+		  __entry->reason)
+);
+
+/*
+ * Tracepoint: kairo_semantic_classified
+ *
+ * Emitted when Stage 5 semantic flags are visible on a request.
+ * CONCEPTUAL-HOOK: semantic flags exist in kairo_hints but may not
+ * be populated in all request paths.
+ */
+TRACE_EVENT(kairo_semantic_classified,
+	TP_PROTO(unsigned int dev, sector_t sector, unsigned int nr_bytes,
+		 unsigned int ephemeral, unsigned int recomputable,
+		 unsigned int avoid_pagecache, unsigned int no_strong_durability),
+
+	TP_ARGS(dev, sector, nr_bytes, ephemeral, recomputable,
+		avoid_pagecache, no_strong_durability),
+
+	TP_STRUCT__entry(
+		__field(unsigned int, dev)
+		__field(sector_t, sector)
+		__field(unsigned int, nr_bytes)
+		__field(unsigned int, ephemeral)
+		__field(unsigned int, recomputable)
+		__field(unsigned int, avoid_pagecache)
+		__field(unsigned int, no_strong_durability)
+	),
+
+	TP_fast_assign(
+		__entry->dev			= dev;
+		__entry->sector			= sector;
+		__entry->nr_bytes		= nr_bytes;
+		__entry->ephemeral		= ephemeral;
+		__entry->recomputable		= recomputable;
+		__entry->avoid_pagecache	= avoid_pagecache;
