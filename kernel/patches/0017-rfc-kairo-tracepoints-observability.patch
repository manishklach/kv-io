+/*
+ * Stage 8: Kairo trace enum comments for tracepoint payload self-description.
+ *
+ * These integer ranges are documented for trace consumers.
+ * They are not new enums — they reference existing Kairo internal values.
+ *
+ * kairo_io_class:      0=NONE 1=DECODE_READ 2=PREFETCH_READ
+ *                      3=PREFILL_WRITE 4=EVICT 5=NORMAL
+ * kairo_hint_source:   0=NONE 1=IOPRIO 2=RWF 3=BOTH
+ * kairo_backend_class: 0=NONE 1=SHORT_LIVED 2=SESSION_LOCAL
+ *                      3=MODEL_LOCAL 4=RECOMPUTABLE 5=PERSISTENT
+ */
diff --git a/block/blk-mq.c b/block/blk-mq.c
index 77ca638..a13b9e0 100644
--- a/block/blk-mq.c
+++ b/block/blk-mq.c
@@ -XXX,6 +XXX,XXX @@
+#include <trace/events/kairo.h>
+
+/*
+ * CONCEPTUAL-HOOK: trace_kairo_request_classified() call site.
+ *
+ * This should be placed near kairo_classify_rq() or equivalent
+ * classification point where the request has valid sector/bytes/op metadata
+ * and the classified io_class is known.
+ *
+ * VERSION-SENSITIVE: exact placement depends on where
+ * blk_mq_kairo_init_request() and rq_set_kairo_from_bio() are called
+ * in the target kernel version.
+ */
+static void kairo_trace_classify(struct request *rq, unsigned int io_class,
+				 unsigned int hint_source)
+{
+	trace_kairo_request_classified(
+		rq->q->sysfs_dev->devt, blk_rq_pos(rq), blk_rq_bytes(rq),
+		rq->cmd_flags, rq->ioprio, io_class, hint_source,
+		rq->kairo_hints.flags);
+}
diff --git a/block/mq-deadline.c b/block/mq-deadline.c
index 2d26bef..48fe5f9 100755
--- a/block/mq-deadline.c
+++ b/block/mq-deadline.c
@@ -XXX,6 +XXX,XXX @@
+#include <trace/events/kairo.h>
+
+/*
+ * CONCEPTUAL-HOOK: trace_kairo_scheduler_decision() call sites.
+ *
+ * These should be placed at the dispatch decision points in
+ * dd_kairo_dispatch_decode_request(), dd_kairo_dispatch_prefetch_request(),
+ * dd_kairo_should_demote_prefill(), dd_kairo_should_demote_evict(), and
+ * dd_dispatch_request().
+ *
+ * COMPILE-TARGET: individual tracepoint calls.
+ */
+
+/*
+ * Decode dispatch trace.
+ * Place inside dd_kairo_dispatch_decode_request() after request is selected.
+ */
+static void kairo_trace_decode_dispatch(struct request *rq,
+					unsigned int budget_used)
+{
+	trace_kairo_decode_dispatch(
+		rq->q->sysfs_dev->devt, blk_rq_pos(rq), blk_rq_bytes(rq),
+		budget_used, rq->kairo_hints.kairo_deadline_ns);
+}
+
+/*
+ * Prefetch dispatch trace.
+ * Place inside dd_kairo_dispatch_prefetch_request() after request is selected.
+ */
+static void kairo_trace_prefetch_dispatch(struct request *rq,
+					  unsigned int budget_used,
+					  unsigned int deadline_near)
+{
+	trace_kairo_prefetch_dispatch(
+		rq->q->sysfs_dev->devt, blk_rq_pos(rq), blk_rq_bytes(rq),
+		budget_used, rq->kairo_hints.kairo_deadline_ns, deadline_near);
+}
+
+/*
+ * Demotion trace.
+ * Place inside dd_kairo_should_demote_prefill() / dd_kairo_should_demote_evict()
+ * when demotion decision is made.
+ */
+static void kairo_trace_demote(struct request *rq, unsigned int reason,
+			       unsigned int starvation_escape)
+{
+	trace_kairo_write_demoted(
+		rq->q->sysfs_dev->devt, blk_rq_pos(rq), blk_rq_bytes(rq),
+		rq->kairo_hints.io_class, reason, starvation_escape);
+}
+
+/*
+ * Scheduler decision trace.
+ * Place in dd_dispatch_request() when a Kairo-aware decision is made.
+ */
+static void kairo_trace_scheduler_decision(struct request *rq,
+					   unsigned int decision,
+					   unsigned int reason)
+{
