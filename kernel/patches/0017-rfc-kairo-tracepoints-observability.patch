+ * Emitted when Stage 6 placement/lifetime metadata is present.
+ * COMPILE-TARGET: metadata fields are populated by blk_mq_kairo_default_placement()
+ * in the 0007 patch.
+ */
+TRACE_EVENT(kairo_placement_classified,
