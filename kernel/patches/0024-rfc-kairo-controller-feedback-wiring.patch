From: Kairo Authors <kairo@research>
Date: Wed Jun 24 14:00:00 2026 +0000
Subject: [RFC/POC] 0024: controller feedback wiring

RFC/POC — Not for LKML submission.

Wire decode latency observations into the Stage 10 adaptive controller
(patch 0018) by adding timestamp metadata to request hints and feeding
queue latency into the Stage 13 histogram (patch 0023).

This creates the conceptual bridge:
  request classified as decode
    -> kairo_mark_classify_time() records ktime_get_ns()
    -> dd_kairo_dispatch_decode_request() records dispatch time
    -> decode_queue_latency computed as dispatch_time - classify_time
    -> dd_kairo_controller_note_decode_latency() called with latency
    -> histogram updated
    -> controller update uses histogram for p95/p99
    -> histogram reset for next window

Request metadata added to struct kairo_request_hints:
  u64 classify_time_ns;
  u64 dispatch_time_ns;
  u64 decode_queue_latency_us;

Helpers:
  kairo_mark_classify_time(rq, now_ns)
  kairo_mark_dispatch_time(rq, now_ns)
  kairo_decode_queue_latency_us(rq, now_ns)

Controller integration:
  dd_kairo_dispatch_decode_request() calls kairo_mark_dispatch_time()
    and dd_kairo_controller_note_decode_latency() for decode reads.
  dd_kairo_controller_update() uses Stage 13 histogram for p95/p99,
    then resets histogram when window expires.
  If classify_time_ns is zero, skip and increment
    kairo_controller_missing_timestamp.

New counters in struct kairo_latency_controller:
  kairo_controller_latency_samples
  kairo_controller_missing_timestamp
  kairo_controller_latency_updates
  kairo_controller_histogram_resets
  kairo_controller_decode_latency_gt_target

Tracepoint (documented only, not wired):
  kairo_controller_sample — sector, nr_bytes, latency_us,
    target_decode_p99_us, samples

All integration points are CONCEPTUAL-HOOK / LINUX-6.8-CHECK.
Timestamp recording in kairo_init_request_hints() is compile-targeted.

Signed-off-by: Kairo Authors <kairo@research>
---
 block/mq-deadline.c       | 220 +++++++++++++++++++++++++++++++++++---
 include/linux/blk-mq.h    |  56 ++++++++++
 2 files changed, 259 insertions(+), 17 deletions(-)

diff --git a/include/linux/blk-mq.h b/include/linux/blk-mq.h
index abcdef2..1234568 100644
--- a/include/linux/blk-mq.h
+++ b/include/linux/blk-mq.h
@@ -1,3 +1,59 @@
+/*
+ * CONCEPTUAL-HOOK: Add request timestamp metadata for controller feedback.
+ *
+ * These fields track the decode request lifecycle:
+ *   classify_time_ns      — set when request class is determined
+ *   dispatch_time_ns      — set when request is dispatched to driver
+ *   decode_queue_latency_us — computed queue delay (dispatch - classify)
+ *
+ * LINUX-6.8-CHECK: The struct kairo_request_hints is embedded in
+ * struct request. Adding fields increases request struct size. Verify
+ * that the target kernel does not have strict sizeof(struct request)
+ * constraints (e.g. slab cache alignment in blk-mq).
+ */
 struct kairo_request_hints {
 	enum kairo_io_class io_class;
 	u64 deadline_ns;
 	u32 prefetch_distance;
 	u32 flags;
+	/* CONCEPTUAL-HOOK: Timestamp metadata for controller feedback */
+	u64 classify_time_ns;
+	u64 dispatch_time_ns;
+	u64 decode_queue_latency_us;
 };
+
+/*
+ * CONCEPTUAL-HOOK: Mark the classify time on a request.
+ *
+ * Called when a request's Kairo I/O class is determined (usually at
+ * request initialization time in blk-mq). For decode reads this
+ * establishes the start of the queue latency measurement.
+ */
+static inline void
+kairo_mark_classify_time(struct request *rq, u64 now_ns)
+{
+	if (likely(rq && kairo_is_decode_read(rq)))
+		rq->kairo_hints.classify_time_ns = now_ns;
+}
+
+/*
+ * CONCEPTUAL-HOOK: Mark the dispatch time on a request.
+ *
+ * Called when a request is dispatched from the scheduler to the
+ * driver. For decode reads this captures the end of queue delay.
+ */
+static inline void
+kairo_mark_dispatch_time(struct request *rq, u64 now_ns)
+{
+	if (likely(rq))
+		rq->kairo_hints.dispatch_time_ns = now_ns;
+}
+
+/*
+ * CONCEPTUAL-HOOK: Compute decode queue latency in microseconds.
+ *
+ * Returns dispatch_time_ns - classify_time_ns converted to us,
+ * or 0 if either timestamp is missing.
+ */
+static inline u64
+kairo_decode_queue_latency_us(struct request *rq, u64 now_ns)
+{
+	if (unlikely(!rq || !rq->kairo_hints.classify_time_ns ||
+		     !rq->kairo_hints.dispatch_time_ns))
+		return 0;
+	return div64_u64(rq->kairo_hints.dispatch_time_ns -
+			 rq->kairo_hints.classify_time_ns, 1000);
+}
diff --git a/block/mq-deadline.c b/block/mq-deadline.c
index a9b1e2c..c3d4e5f 100755
--- a/block/mq-deadline.c
+++ b/block/mq-deadline.c
@@ -102,6 +102,12 @@ struct kairo_latency_controller {
 	u64				controller_release_write_events;
