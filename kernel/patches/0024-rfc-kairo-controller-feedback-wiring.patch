+	u64				controller_missing_timestamp;
+	u64				controller_latency_updates;
+	u64				controller_histogram_resets;
+	u64				controller_decode_latency_gt_target;
 };
 
 #define KAIRO_CTRL_MIN_SAMPLES		64
@@ -131,6 +137,7 @@ static void dd_kairo_controller_init(struct deadline_data *dd)
 {
 	struct kairo_latency_controller *ctrl = &dd->kairo_lat_ctrl;
 
+	kairo_latency_histogram_reset(&ctrl->decode_hist);
 	ctrl->mode = KAIRO_CTRL_OFF;
 	ctrl->target_decode_p99_us = 5000; /* 5 ms default target */
 	ctrl->control_window_ns = 1000000000ULL; /* 1 second window */
@@ -151,6 +158,12 @@ static void dd_kairo_controller_init(struct deadline_data *dd)
 	ctrl->controller_release_write_events = 0;
 	ctrl->controller_insufficient_samples = 0;
+
+	/* Stage 14: Initialize feedback counters */
+	ctrl->controller_latency_samples = 0;
+	ctrl->controller_missing_timestamp = 0;
+	ctrl->controller_latency_updates = 0;
+	ctrl->controller_histogram_resets = 0;
+	ctrl->controller_decode_latency_gt_target = 0;
 }
 
 /*
@@ -158,9 +171,13 @@ static void dd_kairo_controller_init(struct deadline_data *dd)
  * completion latency for the controller's sample window.
  *
  * CONCEPTUAL-HOOK: Called from the blk-mq completion path or from a
- * mq-deadline request completion hook when a decode-class request
- * completes. Latency in microseconds from issue to completion.
+ * mq-deadline dispatch hook when a decode-class request is dispatched.
+ * Latency in microseconds represents queue delay from classification
+ * to dispatch.
+ *
+ * Stage 14: Now feeds into the Stage 13 histogram. If the timestamp
+ * is zero (classify_time not set), increments missing_timestamp and
+ * skips the sample.
  */
 static void dd_kairo_controller_note_decode_latency(struct deadline_data *dd,
 						    u64 latency_us)
@@ -169,9 +186,25 @@ static void dd_kairo_controller_note_decode_latency(struct deadline_data *dd,
 
 	if (ctrl->mode == KAIRO_CTRL_OFF)
 		return;
-	ctrl->decode_samples++;
-	ctrl->decode_latency_sum_us += latency_us;
-	if (latency_us > ctrl->decode_latency_max_us)
-		ctrl->decode_latency_max_us = latency_us;
+
+	ctrl->controller_latency_samples++;
+
+	if (latency_us == 0) {
+		ctrl->controller_missing_timestamp++;
+		return;
+	}
+
+	/* CONCEPTUAL-HOOK: Feed into Stage 13 histogram */
+	kairo_latency_histogram_add(&ctrl->decode_hist, latency_us);
+
+	/* Track whether observed latency exceeds target */
+	if (ctrl->target_decode_p99_us > 0 &&
+	    latency_us > ctrl->target_decode_p99_us) {
+		ctrl->controller_decode_latency_gt_target++;
+	}
+
+	/* CL: remove-old-legacy-window — histogram now tracks samples/sum/max */
+	(void)ctrl->decode_samples;
+	(void)ctrl->decode_latency_sum_us;
+	(void)ctrl->decode_latency_max_us;
 }
 
 /*
@@ -300,14 +333,24 @@ static void dd_kairo_controller_apply(struct deadline_data *dd)
  * CONCEPTUAL-HOOK: Exact call site depends on scheduler integration.
  * Options include:
  *   (a) In dd_dispatch_request(), check time and call if window elapsed.
- *   (b) In a per-device timer callback.
- *   (c) In the blk-mq completion path via a request completion hook.
+ *
+ * Stage 14: Uses Stage 13 histogram for p95/p99 computation and
+ * resets histogram when the control window expires.
  *
  * Returns true if a controller update was performed, false otherwise.
  */
 static bool dd_kairo_controller_update(struct deadline_data *dd, u64 now_ns)
 {
 	struct kairo_latency_controller *ctrl = &dd->kairo_lat_ctrl;
+	struct kairo_latency_histogram *hist = &ctrl->decode_hist;
 
 	if (ctrl->mode == KAIRO_CTRL_OFF)
 		return false;
@@ -319,21 +362,29 @@ static bool dd_kairo_controller_update(struct deadline_data *dd, u64 now_ns)
 	ctrl->last_control_update_ns = now_ns;
 
-	/* Compute percentiles from accumulated samples */
-	dd_kairo_controller_compute_pXX(ctrl);
+	ctrl->controller_latency_updates++;
+
+	/* Compute percentiles from histogram (Stage 13) */
+	dd_kairo_controller_update_from_hist(ctrl);
 
-	/* Insufficient samples: stay in observe, do not act */
-	if (ctrl->decode_samples < KAIRO_CTRL_MIN_SAMPLES) {
+	/* Insufficient samples: stay in observe, do not act.
+	 * Uses histogram samples (Stage 13) instead of legacy window. */
+	if (hist->samples < KAIRO_CTRL_MIN_SAMPLES) {
 		ctrl->controller_insufficient_samples++;
-		/* Reset and wait for next window */
-		ctrl->decode_samples = 0;
-		ctrl->decode_latency_sum_us = 0;
-		ctrl->decode_latency_max_us = 0;
+		kairo_latency_histogram_reset(hist);
+		ctrl->controller_histogram_resets++;
 		return true;
 	}
 
 	/* Apply policy if in adaptive mode */
-	if (ctrl->mode == KAIRO_CTRL_ADAPTIVE)
+	if (ctrl->mode == KAIRO_CTRL_ADAPTIVE) {
 		dd_kairo_controller_apply(dd);
+	}
 
-	/* Reset sample window */
-	ctrl->decode_samples = 0;
-	ctrl->decode_latency_sum_us = 0;
-	ctrl->decode_latency_max_us = 0;
+	/* Reset histogram for next window */
+	kairo_latency_histogram_reset(hist);
+	ctrl->controller_histogram_resets++;
 
 	return true;
 }
@@ -358,10 +409,17 @@ static struct request *dd_kairo_dispatch_decode_request(struct deadline_data *dd
 		if (deadline_after(deadline, now))
 			continue;
 		rq = fifo->next;
+
+		/* CONCEPTUAL-HOOK: Record dispatch time and feed latency
+		 * into the controller for decode-class requests.
+		 * LINUX-6.8-CHECK: Verify ktime_get_ns() availability
+		 * at this call site. */
+		kairo_mark_dispatch_time(rq, ktime_get_ns());
+		dd_kairo_controller_note_decode_latency(dd,
+			kairo_decode_queue_latency_us(rq, ktime_get_ns()));
+
 		return rq;
 	}
+
+	/* CONCEPTUAL-HOOK: Also check kairo_prefetch_dispatches FIFO
+	 * for prefetch requests; skip controller feedback for non-decode. */
 	return NULL;
 }
 
@@ -1249,6 +1307,41 @@ SHOW_INT(deadline_fifo_batch_show, dd->fifo_batch);
+/* Stage 14: Controller feedback sysfs counters */
