+ *     TP_PROTO(unsigned int dev,
+ *              sector_t sector,
+ *              unsigned int nr_bytes,
+ *              unsigned long long latency_us,
+ *              unsigned long long target_us,
+ *              unsigned long long samples),
+ *
+ *     TP_ARGS(dev, sector, nr_bytes, latency_us, target_us, samples),
+ *
+ *     TP_STRUCT__entry(
+ *         __field(unsigned int, dev)
+ *         __field(sector_t, sector)
+ *         __field(unsigned int, nr_bytes)
+ *         __field(unsigned long long, latency_us)
+ *         __field(unsigned long long, target_us)
+ *         __field(unsigned long long, samples)
