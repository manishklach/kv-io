@@ -1485,3 +1587,59 @@ static struct elv_fs_entry deadline_attrs[] = {
+/*
+ * Tracepoint: kairo_controller_sample (documented, not wired)
+ *
+ * CONCEPTUAL-HOOK: This tracepoint should be added to the Stage 8
+ * tracepoint set (0017) after controller feedback validation.
+ *
+ * Emitted for each decode request whose latency is fed into the
+ * controller histogram. Fields:
+ *
+ *   sector            - request sector
+ *   nr_bytes          - request size in bytes
+ *   latency_us        - decode queue latency (dispatch_time - classify_time)
