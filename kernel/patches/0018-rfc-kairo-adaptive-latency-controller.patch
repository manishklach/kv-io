+/*
+ * Stage 10: Kairo controller update tracepoint.
+ *
+ * CONCEPTUAL-HOOK: This tracepoint is described here for documentation
+ * purposes. It is not added to 0017 to avoid modifying the existing
+ * tracepoint patch. If the controller is validated, this tracepoint
+ * should be added to the Stage 8 tracepoint set.
+ *
+ * Tracepoint: kairo_controller_update
+ *
+ * Emitted when the adaptive latency controller performs a periodic
+ * update. Fields expose the control decision for offline analysis.
+ *
+ * Not stable ABI. For local kernel research only.
+ *
+ * TRACE_EVENT(kairo_controller_update,
+ *     TP_PROTO(unsigned int dev,
+ *              unsigned long long target_decode_p99_us,
+ *              unsigned long long observed_decode_p99_us,
+ *              unsigned int old_decode_budget,
+ *              unsigned int new_decode_budget,
+ *              unsigned int old_prefetch_budget,
+ *              unsigned int new_prefetch_budget,
+ *              unsigned int action,
+ *              unsigned int reason),
+ *
+ *     TP_ARGS(dev, target_decode_p99_us, observed_decode_p99_us,
+ *             old_decode_budget, new_decode_budget,
+ *             old_prefetch_budget, new_prefetch_budget,
+ *             action, reason),
+ *
+ *     TP_STRUCT__entry(
+ *         __field(unsigned int, dev)
+ *         __field(unsigned long long, target_decode_p99_us)
+ *         __field(unsigned long long, observed_decode_p99_us)
+ *         __field(unsigned int, old_decode_budget)
+ *         __field(unsigned int, new_decode_budget)
+ *         __field(unsigned int, old_prefetch_budget)
+ *         __field(unsigned int, new_prefetch_budget)
+ *         __field(unsigned int, action)
+ *         __field(unsigned int, reason)
+ *     ),
+ *
+ *     TP_fast_assign(
+ *         __entry->dev = dev;
+ *         __entry->target_decode_p99_us = target_decode_p99_us;
+ *         __entry->observed_decode_p99_us = observed_decode_p99_us;
+ *         __entry->old_decode_budget = old_decode_budget;
+ *         __entry->new_decode_budget = new_decode_budget;
+ *         __entry->old_prefetch_budget = old_prefetch_budget;
+ *         __entry->new_prefetch_budget = new_prefetch_budget;
+ *         __entry->action = action;
+ *         __entry->reason = reason;
+ *     ),
+ *
+ *     TP_printk("dev=%u target_p99=%llu obs_p99=%llu "
+ *               "decode_budget=%u->%u prefetch_budget=%u->%u "
+ *               "action=%u reason=%u",
+ *               __entry->dev, __entry->target_decode_p99_us,
+ *               __entry->observed_decode_p99_us,
+ *               __entry->old_decode_budget, __entry->new_decode_budget,
+ *               __entry->old_prefetch_budget, __entry->new_prefetch_budget,
+ *               __entry->action, __entry->reason)
+ * );
+ *
+ * Action values:
+ *   0 = no change (observe only)
+ *   1 = boost (increase decode budget)
