+/*
+ * Stage 10: Kairo adaptive decode tail-latency controller.
+ *
+ * This controller adjusts decode budget, prefetch budget, and write
+ * demotion pressure based on observed decode request latency.
+ *
+ * Design rationale:
+ *   AI inference decode latency is the primary QoS metric. Static budgets
+ *   configured via sysfs work well for steady-state workloads but do not
+ *   adapt to decode pressure spikes. The controller uses observed decode
+ *   p99 latency as the control signal.
+ *
+ *   When decode p99 exceeds a configurable target:
+ *   - decode budget is increased to allow more decode requests per dispatch
+ *   - prefetch budget is reduced to conserve I/O resources for decode
+ *   - write demotion pressure is increased (prefill/evict yield more)
+ *   - the write starvation escape remains active to prevent write-side
+ *     complete starvation
+ *
+ *   When decode p99 is within target:
+ *   - decode budget slowly relaxes toward the base (user-configured) value
+ *   - prefetch budget is gradually restored
+ *   - write demotion pressure eases
+ *
+ *   When too few decode samples are available, the controller remains in
+ *   OBSERVE mode and does not overreact.
+ *
+ * COMPILE-RISK: LOW. Self-contained static helpers. No external deps
+ * beyond existing kairo_enable and deadline_data fields.
+ */
+
+enum kairo_controller_mode {
+	KAIRO_CTRL_OFF = 0,
+	KAIRO_CTRL_OBSERVE,
+	KAIRO_CTRL_ADAPTIVE,
+};
+
+struct kairo_latency_controller {
+	enum kairo_controller_mode	mode;
+
+	/* Target and observed latency (microseconds) */
+	u64				target_decode_p99_us;
+	u64				observed_decode_p99_us;
+	u64				observed_decode_p95_us;
+	u64				observed_decode_avg_us;
+
+	/* Budget tracking */
+	u32				base_decode_budget;
+	u32				adaptive_decode_budget;
+	u32				base_prefetch_budget;
+	u32				adaptive_prefetch_budget;
+
+	/* Control window timing */
+	u64				control_window_ns;
+	u64				last_control_update_ns;
+
+	/* Decode latency sample accumulator */
+	u64				decode_samples;
+	u64				decode_latency_sum_us;
+	u64				decode_latency_max_us;
+
+	/* Controller event counters */
+	u64				controller_updates;
+	u64				controller_boost_events;
+	u64				controller_relax_events;
+	u64				controller_throttle_prefetch_events;
+	u64				controller_release_write_events;
+	u64				controller_insufficient_samples;
+};
+
+#define KAIRO_CTRL_MIN_SAMPLES		64
+#define KAIRO_CTRL_MAX_DECODE_BUDGET	32
+#define KAIRO_CTRL_MIN_PREFETCH_BUDGET	1
+#define KAIRO_CTRL_RELAX_STEP		1
+#define KAIRO_CTRL_BOOST_STEP		2
+
+/*
+ * Controller constants for write demotion pressure adjustment.
+ * When decode is under stress, prefill and evict demotion thresholds
+ * shift to be more aggressive about yielding to decode reads.
+ */
+#define KAIRO_CTRL_WRITE_DEMOTE_BOOST	1
+#define KAIRO_CTRL_WRITE_DEMOTE_RELAX	0
+
+/*
+ * dd_kairo_controller_init - Initialize the latency controller for a
+ * deadline_data instance.
+ *
+ * CONCEPTUAL-HOOK: Called once during mq-deadline elevator init, after
+ * the deadline_data struct is allocated. Sets defaults that match the
+ * existing static budget values.
+ */
+static void dd_kairo_controller_init(struct deadline_data *dd)
+{
+	struct kairo_latency_controller *ctrl = &dd->kairo_lat_ctrl;
+
+	ctrl->mode = KAIRO_CTRL_OFF;
+	ctrl->target_decode_p99_us = 5000; /* 5 ms default target */
+	ctrl->control_window_ns = 1000000000ULL; /* 1 second window */
+	ctrl->last_control_update_ns = 0;
+
+	ctrl->base_decode_budget = kairo_decode_budget;
+	ctrl->adaptive_decode_budget = kairo_decode_budget;
+	ctrl->base_prefetch_budget = kairo_prefetch_budget;
+	ctrl->adaptive_prefetch_budget = kairo_prefetch_budget;
+
+	ctrl->decode_samples = 0;
+	ctrl->decode_latency_sum_us = 0;
+	ctrl->decode_latency_max_us = 0;
+
+	ctrl->controller_updates = 0;
+	ctrl->controller_boost_events = 0;
+	ctrl->controller_relax_events = 0;
+	ctrl->controller_throttle_prefetch_events = 0;
+	ctrl->controller_release_write_events = 0;
+	ctrl->controller_insufficient_samples = 0;
+}
+
+/*
+ * dd_kairo_controller_note_decode_latency - Record a decode request's
+ * completion latency for the controller's sample window.
+ *
+ * CONCEPTUAL-HOOK: Called from the blk-mq completion path or from a
+ * mq-deadline request completion hook when a decode-class request
+ * completes. Latency in microseconds from issue to completion.
+ */
+static void dd_kairo_controller_note_decode_latency(struct deadline_data *dd,
+						    u64 latency_us)
+{
+	struct kairo_latency_controller *ctrl = &dd->kairo_lat_ctrl;
+
+	ctrl->decode_samples++;
+	ctrl->decode_latency_sum_us += latency_us;
+	if (latency_us > ctrl->decode_latency_max_us)
+		ctrl->decode_latency_max_us = latency_us;
+}
+
+/*
+ * dd_kairo_controller_compute_pXX - Compute approximate p95 and p99 from
+ * the sample window. Since the controller only stores sum and max, the
+ * percentile computation is intentionally coarse: it estimates based on
+ * the ratio of max to average.
+ *
+ * CONCEPTUAL-HOOK: A real implementation would store a latency histogram
+ * (e.g. exponential buckets) for precise pXX computation. This simplified
+ * version uses a heuristic: p99 ~ avg + 3 * (max - avg) / 4, p95 ~ avg +
+ * (max - avg) / 2. These are arbitrary RFC constants.
+ */
+static void dd_kairo_controller_compute_pXX(struct kairo_latency_controller *ctrl)
+{
+	u64 avg_us = 0;
+	u64 range_us;
+
+	if (ctrl->decode_samples == 0) {
+		ctrl->observed_decode_avg_us = 0;
+		ctrl->observed_decode_p95_us = 0;
+		ctrl->observed_decode_p99_us = 0;
+		return;
+	}
+
+	avg_us = div64_u64(ctrl->decode_latency_sum_us, ctrl->decode_samples);
+	ctrl->observed_decode_avg_us = avg_us;
+
+	range_us = ctrl->decode_latency_max_us - avg_us;
+	ctrl->observed_decode_p95_us = avg_us + div64_u64(range_us, 2);
+	ctrl->observed_decode_p99_us = avg_us + div64_u64(range_us * 3, 4);
+
+	if (ctrl->observed_decode_p99_us < avg_us)
+		ctrl->observed_decode_p99_us = avg_us;
+	if (ctrl->observed_decode_p95_us < avg_us)
+		ctrl->observed_decode_p95_us = avg_us;
+}
+
+/*
+ * dd_kairo_controller_apply - Apply the controller decision to adjust
+ * scheduling budgets.
+ *
+ * Policy:
+ *   If observed_decode_p99_us > target_decode_p99_us:
+ *     - Boost adaptive_decode_budget by BOOST_STEP (capped at MAX)
+ *     - Reduce adaptive_prefetch_budget by BOOST_STEP (floored at MIN)
+ *     - Signal increased write demotion pressure
+ *   If observed_decode_p99_us <= target_decode_p99_us:
+ *     - Relax adaptive_decode_budget by RELAX_STEP (toward base)
+ *     - Restore adaptive_prefetch_budget by RELAX_STEP (toward base)
+ *     - Signal relaxed write demotion pressure
+ *
+ * The global kairo_decode_budget and kairo_prefetch_budget variables
+ * are updated to reflect the controller's decisions. The base budgets
+ * (user-configured via sysfs) are preserved and serve as the relaxation
+ * target.
+ *
+ * CONCEPTUAL-HOOK: This updates global static variables. A real
+ * implementation would make budgets per-device or per-scheduler instance.
+ */
+static void dd_kairo_controller_apply(struct deadline_data *dd)
+{
+	struct kairo_latency_controller *ctrl = &dd->kairo_lat_ctrl;
+
+	ctrl->controller_updates++;
+
+	if (ctrl->observed_decode_p99_us > ctrl->target_decode_p99_us) {
+		/* Under decode pressure: boost decode, throttle prefetch */
+		u32 new_decode_budget = ctrl->adaptive_decode_budget +
+					KAIRO_CTRL_BOOST_STEP;
+		u32 new_prefetch_budget;
+
+		if (new_decode_budget > ctrl->adaptive_prefetch_budget)
+			new_decode_budget = min(new_decode_budget,
+					       (u32)KAIRO_CTRL_MAX_DECODE_BUDGET);
+
+		if (ctrl->adaptive_prefetch_budget >
+		    KAIRO_CTRL_MIN_PREFETCH_BUDGET + KAIRO_CTRL_BOOST_STEP)
+			new_prefetch_budget = ctrl->adaptive_prefetch_budget -
+					      KAIRO_CTRL_BOOST_STEP;
+		else
+			new_prefetch_budget = KAIRO_CTRL_MIN_PREFETCH_BUDGET;
+
+		if (new_decode_budget != ctrl->adaptive_decode_budget) {
+			ctrl->adaptive_decode_budget = new_decode_budget;
+			ctrl->controller_boost_events++;
+			kairo_decode_budget = ctrl->adaptive_decode_budget;
+		}
+
+		if (new_prefetch_budget < ctrl->adaptive_prefetch_budget) {
+			ctrl->adaptive_prefetch_budget = new_prefetch_budget;
+			ctrl->controller_throttle_prefetch_events++;
+			kairo_prefetch_budget = ctrl->adaptive_prefetch_budget;
+		}
+
+		/* Increase write demotion pressure by biasing demotion
+		 * helpers toward earlier yield. This is tracked as a
+		 * conceptual counter; the actual demotion logic in
+		 * dd_kairo_should_demote_prefill/evict uses an implicit
+		 * preference for decode reads already.
+		 */
+		ctrl->controller_release_write_events +=
+			KAIRO_CTRL_WRITE_DEMOTE_BOOST;
+	} else {
+		/* Decode healthy: relax budgets toward base */
+		if (ctrl->adaptive_decode_budget > ctrl->base_decode_budget) {
+			ctrl->adaptive_decode_budget -=
+				min(KAIRO_CTRL_RELAX_STEP,
+				    ctrl->adaptive_decode_budget -
+				    ctrl->base_decode_budget);
+			ctrl->controller_relax_events++;
+			kairo_decode_budget = ctrl->adaptive_decode_budget;
+		}
+
+		if (ctrl->adaptive_prefetch_budget < ctrl->base_prefetch_budget) {
+			ctrl->adaptive_prefetch_budget +=
+				min(KAIRO_CTRL_RELAX_STEP,
+				    ctrl->base_prefetch_budget -
+				    ctrl->adaptive_prefetch_budget);
+			ctrl->controller_relax_events++;
+			kairo_prefetch_budget = ctrl->adaptive_prefetch_budget;
+		}
+	}
+}
+
+/*
+ * dd_kairo_controller_update - Main controller update entry point.
+ *
+ * Called periodically (every control_window_ns) from the dispatch path
+ * or a timer. Samples are accumulated between updates; the controller
+ * computes latency percentiles and applies policy adjustments, then
+ * resets the sample window.
+ *
+ * CONCEPTUAL-HOOK: Exact call site depends on scheduler integration.
+ * Options include:
+ *   (a) In dd_dispatch_request(), check time and call if window elapsed.
+ *   (b) In a per-device timer callback.
+ *   (c) In the blk-mq completion path via a request completion hook.
+ *
+ * Returns true if a controller update was performed, false otherwise.
+ */
+static bool dd_kairo_controller_update(struct deadline_data *dd, u64 now_ns)
+{
+	struct kairo_latency_controller *ctrl = &dd->kairo_lat_ctrl;
+
+	if (ctrl->mode == KAIRO_CTRL_OFF)
+		return false;
+
+	/* Check if control window has elapsed */
+	if (now_ns - ctrl->last_control_update_ns < ctrl->control_window_ns)
+		return false;
+
+	ctrl->last_control_update_ns = now_ns;
+
+	/* Compute percentiles from accumulated samples */
+	dd_kairo_controller_compute_pXX(ctrl);
+
+	/* Insufficient samples: stay in observe, do not act */
+	if (ctrl->decode_samples < KAIRO_CTRL_MIN_SAMPLES) {
+		ctrl->controller_insufficient_samples++;
+		/* Reset and wait for next window */
+		ctrl->decode_samples = 0;
+		ctrl->decode_latency_sum_us = 0;
+		ctrl->decode_latency_max_us = 0;
+		return true;
+	}
+
+	/* Apply policy if in adaptive mode */
+	if (ctrl->mode == KAIRO_CTRL_ADAPTIVE)
+		dd_kairo_controller_apply(dd);
+
+	/* Reset sample window */
+	ctrl->decode_samples = 0;
+	ctrl->decode_latency_sum_us = 0;
+	ctrl->decode_latency_max_us = 0;
+
+	return true;
+}
