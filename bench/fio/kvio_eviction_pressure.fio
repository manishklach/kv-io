[global]
ioengine=io_uring
direct=1
time_based=1
runtime=60
group_reporting=1
filename=${FILENAME}
size=16g
invalidate=0
norandommap=1
randrepeat=0

[decode_read]
rw=randread
bs=1m
iodepth=16
prioclass=1
prio=1

[prefill_write]
rw=write
bs=1m
iodepth=16
prioclass=2
prio=7

[eviction_pressure]
rw=trimwrite
bs=1m
iodepth=8
prioclass=3
prio=7
