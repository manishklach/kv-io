[global]
ioengine=io_uring
direct=1
time_based=1
runtime=60
group_reporting=1
filename=${FILENAME}
size=16g
invalidate=0
norandommap=1
randrepeat=0

[decode_read]
rw=randread
bs=1m
iodepth=16
prioclass=1
prio=1
thinktime=100
thinktime_blocks=1

[prefetch_read]
rw=read
bs=1m
iodepth=8
offset_increment=1m
prioclass=1
prio=2

[prefill_write]
rw=write
bs=1m
iodepth=32
prioclass=2
prio=4
